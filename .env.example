# ZeroHermes Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM Provider Settings
# =============================================================================

# Provider: openrouter, openai, anthropic, zai
LLM_PROVIDER=openrouter

# Default model
LLM_MODEL=anthropic/claude-sonnet-4

# =============================================================================
# API Keys (REQUIRED - choose at least one)
# =============================================================================

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=your_openai_key_here

# Anthropic (https://console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Z.ai (https://z.ai/dashboard/api-keys)
# ZAI_API_KEY=your_zai_key_here

# =============================================================================
# Telegram Bot (OPTIONAL)
# =============================================================================

# Bot token from @BotFather
# TG_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Restrict to specific chats (comma-separated Telegram user IDs)
# TG_ALLOWED_CHATS=123456789,987654321

# =============================================================================
# Advanced Settings
# =============================================================================

# API timeout in seconds
LLM_TIMEOUT=120

# Max retry attempts
LLM_MAX_RETRIES=3

# Debug mode (set to 1 to enable)
# DEBUG=1
